# ========================================
# AI Content Agent System — Environment
# ========================================

# Apify Token (preferred scraper for Instagram/YouTube/Twitter, matching the guide)
# Get yours at: https://console.apify.com/account/integrations
APIFY_TOKEN=your_apify_token_here

# OpenAI API Key (for voice analysis, script generation, hook generation, and optional transcript workflows)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Flask secret
FLASK_SECRET_KEY=change-this-to-a-random-string

# Optional: Competitor handles (comma-separated)
COMPETITOR_HANDLES=

# Optional: Instagram login for Instaloader.
# A logged-in account or session is usually required because Instagram blocks anonymous scraping.
IG_USERNAME=
IG_PASSWORD=
# Alternative to password: paste your Instagram sessionid cookie here.
IG_SESSIONID=

# Optional: Custom keywords (comma-separated)
SCRAPE_KEYWORDS=Claude Code,AI agents,N8N automation,AI coding,vibe coding
